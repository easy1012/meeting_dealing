# ============================================================
#  meeting_dealing — 환경변수 설정 예시
#  실제 키를 채운 .env 파일을 만들어 사용하세요.
#  .env 파일은 절대 git에 커밋하지 마세요!
# ============================================================

# HuggingFace Access Token
# https://huggingface.co/settings/tokens 에서 발급
# pyannote/speaker-diarization-3.1 라이선스 동의 필수
HF_TOKEN=hf_your_token_here

# 사용할 디바이스: "cuda" | "mps" | "cpu"
DEVICE=cuda

# STT 언어 힌트 (None이면 자동감지)
WHISPER_LANGUAGE=ko

# sLLM 모델 ID (HuggingFace Hub)
SLLM_MODEL_ID=google/gemma-3-4b-it

# Whisper 모델 크기: tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=large-v3

# 결과 출력 경로
OUTPUT_DIR=rsc/output
